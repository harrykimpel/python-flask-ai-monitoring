        {
          "id": "537889005",
          "title": "Raw Inputs & Outputs",
          "layout": {
            "column": 1,
            "row": 9,
            "width": 12,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  NR_ACCOUNT_ID
                ],
                "query": "FROM Span with jparse(`gen_ai.input.messages`, '[*].parts[*].content') as userPrompt, jparse(`gen_ai.output.messages`, '[*].parts[*].content') as agentResponse, jparse(`gen_ai.output.messages`, '[*].parts[*].type') as agentSequence select otel.library.name , userPrompt, agentResponse, agentSequence \r since 1 week ago where gen_ai.input.messages is not null"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "537889006",
          "title": "OpenTelemetry Spans",
          "layout": {
            "column": 1,
            "row": 12,
            "width": 12,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  NR_ACCOUNT_ID
                ],
                "query": "FROM Span select `duration.ms`, `gen_ai.usage.input_tokens`, `gen_ai.usage.output_tokens`, `gen_ai.usage.input_tokens`+`gen_ai.usage.output_tokens`, `gen_ai.input.messages`, `gen_ai.output.messages`\r  since 1 week ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "537889007",
          "title": "Total cost in $",
          "layout": {
            "column": 1,
            "row": 15,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  NR_ACCOUNT_ID
                ],
                "query": "FROM Span join(from lookup(AIModelCost) select latest(`cost-input`) as costInput, latest(`cost-input-tokens`) as costInputTokens, latest(`cost-output`) as costOutput, latest(`cost-output-tokens`) as costOutputTokens facet response.model as 'gen_ai.request.model') on gen_ai.request.model  select filter(sum(gen_ai.usage.input_tokens)/latest(costInputTokens)*latest(costInput),where (otel.library.name is not null ))+filter(sum(gen_ai.usage.output_tokens)/latest(costOutputTokens)*latest(costOutput),where (otel.library.name is not null)) as 'Cost in $', filter(sum(gen_ai.usage.input_tokens+gen_ai.usage.output_tokens),where (otel.library.name is not null)) as 'Sum tokens'  since 1 week ago facet gen_ai.request.model"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "537889008",
          "title": "Input cost in $",
          "layout": {
            "column": 5,
            "row": 15,
            "width": 4,
            "height": 3
