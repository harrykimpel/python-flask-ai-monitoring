                "query": "FROM Span join(from lookup(AIModelCost) select latest(`cost-output`) as costOutput, latest(`cost-output-tokens`) as costOutputTokens facet response.model as 'gen_ai.request.model' since 1 month ago limit max) on gen_ai.request.model select sum(gen_ai.usage.output_tokens)/latest(costOutputTokens)*latest(costOutput) as 'Cost in $',sum(gen_ai.usage.output_tokens) as 'Sum tokens' where (otel.library.name is not null) since 1 week ago facet gen_ai.request.model limit max  "
